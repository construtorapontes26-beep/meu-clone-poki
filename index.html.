<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>POKI GLOBAL | BRENNO CEO EDITION</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet">
    <style>
        :root { --p-purple: #6a42f4; --p-dark: #4c2fb3; --p-yellow: #ffde00; --p-bg: #5b39d1; --p-cyan: #00f2ff; --card-radius: 20px; --shadow: 0 8px 0 rgba(0,0,0,0.2); --spring: cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Montserrat', sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background: var(--p-dark); background-image: radial-gradient(circle at 50% 0%, var(--p-purple) 0%, var(--p-dark) 75%); background-attachment: fixed; min-height: 100vh; padding-top: 160px; overflow-x: hidden; color: white; }
        header { position: fixed; top: 0; width: 100%; height: 95px; background: var(--p-purple); z-index: 10000; display: flex; align-items: center; justify-content: space-between; padding: 0 40px; border-bottom: 6px solid rgba(0,0,0,0.1); }
        .logo { font-size: 55px; font-weight: 900; color: var(--p-yellow); letter-spacing: -5px; text-transform: lowercase; filter: drop-shadow(4px 4px 0 rgba(0,0,0,0.15)); }
        .search-container { flex: 1; max-width: 700px; margin: 0 40px; position: relative; }
        .search-input { width: 100%; height: 55px; border-radius: 30px; border: none; padding-left: 60px; font-size: 20px; font-weight: 800; outline: none; box-shadow: inset 0 4px 10px rgba(0,0,0,0.2); }
        .top-stats { display: flex; gap: 15px; }
        .stat-card { background: white; color: #333; padding: 12px 25px; border-radius: 50px; font-weight: 900; box-shadow: var(--shadow); display: flex; align-items: center; gap: 10px; }
        .xp-engine { position: fixed; top: 95px; width: 100%; height: 6px; background: rgba(0,0,0,0.3); z-index: 9999; }
        #xp-bar { width: 45%; height: 100%; background: var(--p-cyan); box-shadow: 0 0 15px var(--p-cyan); transition: 0.8s; }
        .cat-bar { position: fixed; top: 101px; width: 100%; height: 65px; background: var(--p-bg); z-index: 9000; display: flex; align-items: center; gap: 15px; padding: 0 30px; overflow-x: auto; scrollbar-width: none; }
        .cat-item { background: rgba(255,255,255,0.1); padding: 12px 25px; border-radius: 40px; font-weight: 800; cursor: pointer; white-space: nowrap; transition: 0.3s; }
        .content-engine { display: flex; max-width: 1850px; margin: 0 auto; padding: 25px; gap: 25px; }
        .poki-grid { flex: 1; display: grid; grid-template-columns: repeat(auto-fill, minmax(145px, 1fr)); grid-auto-rows: 145px; grid-auto-flow: dense; gap: 15px; }
        .game-card { background: white; border-radius: var(--card-radius); position: relative; cursor: pointer; overflow: hidden; box-shadow: var(--shadow); transition: var(--spring); }
        .game-card:hover { transform: scale(1.1) translateY(-10px) rotate(1.5deg); z-index: 100; box-shadow: 0 25px 50px rgba(0,0,0,0.5); }
        .game-card img { width: 100%; height: 100%; object-fit: cover; }
        .game-card .info { position: absolute; bottom: 0; width: 100%; height: 35px; background: white; color: #333; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; text-transform: uppercase; border-top: 1px solid #f0f0f0; }
        .g-big { grid-column: span 2; grid-row: span 2; }
        .friends-panel { width: 320px; background: rgba(0,0,0,0.25); border-radius: 30px; padding: 25px; height: calc(100vh - 200px); position: sticky; top: 180px; }
        #poki-theatre { position: fixed; inset: 0; background: #000; z-index: 200000; display: none; flex-direction: column; }
        .nav-theatre { height: 75px; background: var(--p-purple); display: flex; align-items: center; justify-content: space-between; padding: 0 40px; }
        .back-button { background: var(--p-yellow); border: none; padding: 15px 40px; border-radius: 18px; font-weight: 900; font-size: 18px; cursor: pointer; box-shadow: 0 5px 0 #ccb200; }
        iframe { flex: 1; border: none; background: white; }
    </style>
</head>
<body>
<header>
    <div class="logo">poki</div>
    <div class="search-container"><input type="text" class="search-input" placeholder="Pesquisar entre 300+ jogos..."></div>
    <div class="top-stats">
        <div class="stat-card">💰 500</div>
        <div class="stat-card" style="background:var(--p-yellow)">⭐ LVL 1</div>
    </div>
</header>
<div class="xp-engine"><div id="xp-bar"></div></div>
<nav class="cat-bar"><div class="cat-item">🔥 Popular</div><div class="cat-item">🏃 Ação</div><div class="cat-item">🏍️ Moto</div></nav>
<div class="content-engine">
    <div class="poki-grid" id="grid"></div>
    <aside class="friends-panel"><h3>Amigos Online</h3><div style="margin-top:15px"><b>Brenno (CEO)</b><br><span>Online</span></div></aside>
</div>
<div id="poki-theatre">
    <div class="nav-theatre"><h2>JOGANDO AGORA</h2><button class="back-button" onclick="location.reload()">VOLTAR</button></div>
    <iframe id="iframe"></iframe>
</div>
<script>
    const db = [
        {n:"2048", u:"https://play2048.co/", i:"https://play2048.co/meta/apple-touch-icon.png"},
        {n:"Snake", u:"https://n-p-n.github.io/snake/", i:"https://n-p-n.github.io/snake/apple-touch-icon.png"},
        {n:"Hextris", u:"https://hextris.io/", i:"https://hextris.io/images/touch-icon-114x114.png"}
    ];
    const grid = document.getElementById('grid');
    for(let i=0; i<300; i++) {
        const g = db[i % db.length];
        const card = document.createElement('div');
        card.className = 'game-card' + (i % 15 === 0 ? ' g-big' : '');
        card.innerHTML = `<img src="${g.i}"><div class="info">${g.n}</div>`;
        card.onclick = () => { document.getElementById('poki-theatre').style.display='flex'; document.getElementById('iframe').src=g.u; };
        grid.appendChild(card);
    }
</script>
</body>
</html>
